LLM_WIKI_ENVIRONMENT=production
LLM_WIKI_LOG_LEVEL=info
LLM_WIKI_AUTO_MIGRATE=true

LLM_WIKI_SERVER_HOST=127.0.0.1
LLM_WIKI_SERVER_PORT=8234

LLM_WIKI_CLI_BASE_URL=https://llm-wiki.ifuryst.com/
LLM_WIKI_INSTALL_BASE_URL=https://llm-wiki.ifuryst.com/
LLM_WIKI_CLI_TIMEOUT=10s

LLM_WIKI_POSTGRES_HOST=127.0.0.1
LLM_WIKI_POSTGRES_PORT=5432
LLM_WIKI_POSTGRES_USER=llmwiki
LLM_WIKI_POSTGRES_PASSWORD=change-me
LLM_WIKI_POSTGRES_DATABASE=llmwiki
LLM_WIKI_POSTGRES_SSLMODE=disable

LLM_WIKI_REDIS_ADDR=127.0.0.1:6379
LLM_WIKI_REDIS_PASSWORD=
LLM_WIKI_REDIS_DB=0

LLM_WIKI_MINIO_ENDPOINT=127.0.0.1:19000
LLM_WIKI_MINIO_ACCESS_KEY=minioadmin
LLM_WIKI_MINIO_SECRET_KEY=minioadmin
LLM_WIKI_MINIO_BUCKET=llm-wiki
LLM_WIKI_MINIO_USE_SSL=false

LLM_WIKI_OPENSEARCH_URL=http://127.0.0.1:19200
