DOCMESH_ENVIRONMENT=production
DOCMESH_LOG_LEVEL=info
DOCMESH_AUTO_MIGRATE=true

DOCMESH_SERVER_HOST=127.0.0.1
DOCMESH_SERVER_PORT=8234

DOCMESH_CLI_BASE_URL=https://docmesh.ifuryst.com/
DOCMESH_INSTALL_BASE_URL=https://docmesh.ifuryst.com/
DOCMESH_CLI_TIMEOUT=10s

DOCMESH_POSTGRES_HOST=127.0.0.1
DOCMESH_POSTGRES_PORT=5432
DOCMESH_POSTGRES_USER=docmesh
DOCMESH_POSTGRES_PASSWORD=change-me
DOCMESH_POSTGRES_DATABASE=docmesh
DOCMESH_POSTGRES_SSLMODE=disable

DOCMESH_REDIS_ADDR=127.0.0.1:6379
DOCMESH_REDIS_PASSWORD=
DOCMESH_REDIS_DB=0

DOCMESH_MINIO_ENDPOINT=127.0.0.1:19000
DOCMESH_MINIO_ACCESS_KEY=minioadmin
DOCMESH_MINIO_SECRET_KEY=minioadmin
DOCMESH_MINIO_BUCKET=docmesh
DOCMESH_MINIO_USE_SSL=false

DOCMESH_OPENSEARCH_URL=http://127.0.0.1:19200
